{
  "name": "lifeglance",
  "version": "2.3.6",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20.19.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "build:mobile": "vite build && cap sync",
    "build:ios": "npm run build && cap sync ios && node scripts/sync-ios-version.mjs",
    "sync:ios-version": "node scripts/sync-ios-version.mjs",
    "assets": "capacitor-assets generate --android --ios",
    "android": "npm run build:mobile && cap open android",
    "ios": "npm run build:ios && cap open ios"
  },
  "dependencies": {
    "@capacitor/android": "^8.4.0",
    "@capacitor/core": "^8.4.0",
    "@capacitor/ios": "^8.4.0",
    "@glance-apps/intents": "1.4.0",
    "@glance-apps/sync": "1.5.2",
    "date-fns": "^3.6.0",
    "i18next": "^26.3.1",
    "i18next-browser-languagedetector": "^8.2.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-i18next": "^17.0.8"
  },
  "devDependencies": {
    "@capacitor/assets": "^3.0.5",
    "@capacitor/cli": "^8.4.0",
    "@vitejs/plugin-react": "^4.3.1",
    "fake-indexeddb": "^6.2.5",
    "vite": "^8.0.8",
    "vite-plugin-pwa": "^0.19.8",
    "vitest": "^4.1.5"
  }
}
